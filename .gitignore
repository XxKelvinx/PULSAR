# Ignore generated output only
Artifacts/Output/
Artifacts/out-test/

# Ignore test tracks (large audio files)
Artifacts/Test Tracks/

# Ignore reference source code (third-party)
Reference Open Source/
opus-main/

# Ignore build artifacts
bin/
obj/

# Ignore editor and local settings
.vscode/
.claude/

# Python cache and temporary files
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Misc temporary files
*.log
*.tmp
*.temp
*.swp
*.DS_Store
